# Omnecor (CORTEX) — Environment Configuration Template
# Copy this file to .env and fill in your local values.

# ---------------------------------------------------------------------------
# Core Server Settings
# ---------------------------------------------------------------------------
# The main port for the unified Express + tRPC server.
PORT=3000

# Specific ports for Phase 2 services (if configured to use separate ports).
OMNECOR_PORT=3100
OMNECOR_WS_PORT=3101
OMNECOR_HOST=0.0.0.0

# CORS allowed origins (comma-separated list).
OMNECOR_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment mode (production, development).
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database & Persistence
# ---------------------------------------------------------------------------
# MySQL/MariaDB connection string for Drizzle ORM.
DATABASE_URL=mysql://user:password@localhost:3306/omnecor

# ChromaDB server URL for vector search and long-term memory.
CHROMADB_URL=http://localhost:8000
CHROMA_URL=http://localhost:8000

# Directory for security backups.
OMNECOR_BACKUP_DIR=./backups

# ---------------------------------------------------------------------------
# AI Providers & APIs
# ---------------------------------------------------------------------------
# Primary App ID for OAuth and identification.
VITE_APP_ID=omnecor-local-dev

# JWT Secret for session cookies.
JWT_SECRET=replace_with_a_secure_random_string

# Forge API (Internal project tools).
BUILT_IN_FORGE_API_URL=https://api.forge.example.com
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# OAuth Configuration.
OAUTH_SERVER_URL=https://auth.example.com
OWNER_OPEN_ID=your_openid_identifier

# (Planned) External AI Providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=
GROQ_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ---------------------------------------------------------------------------
# Specialized Module Bridges (Python)
# ---------------------------------------------------------------------------
# Executable paths for local tools.
PYTHON_BIN=python3
BLENDER_BIN=blender
KICAD_CLI_PATH=kicad-cli

# Whisper & TTS Microservice URLs.
WHISPER_SERVER_URL=http://localhost:8001
TTS_SERVER_URL=http://localhost:8002
RVC_SERVER_URL=http://127.0.0.1:8003

# LoRA Fine-tuning output directory.
LORA_OUTPUT_DIR=./lora_outputs
MAX_TRAINING_JOBS=1

# ---------------------------------------------------------------------------
# System Behavior
# ---------------------------------------------------------------------------
# File system watcher debounce interval (ms).
WATCHER_DEBOUNCE_MS=300

# Loop detector threshold (consecutive identical actions before signaling).
LOOP_THRESHOLD=3
LOOP_HISTORY_SIZE=100

# ---------------------------------------------------------------------------
# Frontend (Vite) — Prefixed with VITE_
# ---------------------------------------------------------------------------
# These variables are exposed to the client-side code.
VITE_FRONTEND_FORGE_API_KEY=your_forge_api_key
VITE_FRONTEND_FORGE_API_URL=https://api.forge.example.com
VITE_OAUTH_PORTAL_URL=https://portal.example.com
VITE_WS_URL=ws://localhost:3000/ws

# ---------------------------------------------------------------------------
# OMMESH (Distributed AI Mesh — Phase 9)
# ---------------------------------------------------------------------------
# (Optional) Configuration for local LAN node discovery.
OMMESH_ENABLED=true
OMMESH_NODE_NAME=omnecor-node-01
OMMESH_SECRET=replace_with_mesh_shared_secret
