[Unit]
Description=Omnecor HMCI Backend Server
After=network.target

[Service]
Type=simple
User=omnecor
WorkingDirectory=/opt/omnecor/backend
# Launch the built production server
ExecStart=/usr/bin/node --experimental-specifier-resolution=node dist/index.js
Restart=on-failure
Environment=NODE_ENV=production
# Add paths for hardware bridges if necessary
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

[Install]
WantedBy=multi-user.target
